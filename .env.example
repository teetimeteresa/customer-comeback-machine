# Customer Comeback Machine - Environment Configuration

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-here-change-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_STARTER_PRICE_ID=price_your_starter_price_id
STRIPE_GROWTH_PRICE_ID=price_your_growth_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_DONE_FOR_YOU_PRICE_ID=price_your_done_for_you_price_id

# OpenAI (for AI message generation)
OPENAI_API_KEY=sk-your-openai-api-key

# Database (team-db handles Turso automatically, no need to configure here)

# Email (Resend - recommended for easy setup)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Customer Comeback Machine <noreply@yourdomain.com>

# SMS (Twilio - only if using SMS features)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890