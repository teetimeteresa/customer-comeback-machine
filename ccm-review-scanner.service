[Unit]
Description=CCM Reactive Retention Review Scanner - Weekly
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=agent-infrastructure-expert
Group=team
WorkingDirectory=/home/team/shared
EnvironmentFile=/home/team/shared/.env
ExecStart=/home/engine/.nvm/versions/node/v24.16.0/bin/node /home/team/shared/scripts/review_scanner.js
StandardOutput=journal
StandardError=journal
PrivateTmp=yes